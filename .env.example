# ── Aiven MySQL credentials ─────────────────────────────────────────────────
# Copy .env.example to .env and set your real credentials.
# NEVER commit .env!
DB_URL=jdbc:mysql://YOUR_HOST:YOUR_PORT/YOUR_DB?ssl-mode=REQUIRED&useSSL=true&serverTimezone=UTC
DB_USER=YOUR_DB_USER
DB_PASSWORD=YOUR_DB_PASSWORD

# ── Mistral AI ───────────────────────────────────────────────────────────────
MISTRAL_API_KEY=YOUR_MISTRAL_API_KEY
MISTRAL_FALLBACK_API_KEY=YOUR_MISTRAL_FALLBACK_API_KEY

# ── OpenAI (primary) ─────────────────────────────────────────────────────────
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o-mini

# ── Gemini (primary) ─────────────────────────────────────────────────────────
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-1.5-flash
